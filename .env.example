# Kopiiki local configuration
#
# Copy this file to `.env`, then fill in the values you need.
# `.env` is ignored by git and should not be committed.

# Required for Design Capsule AI real Gemini mode.
GEMINI_API_KEY=

# Optional. Defaults to gemini-3-pro-preview for highest-quality multimodal design analysis.
# If your account does not have preview access, use gemini-2.5-pro.
KOPIIKI_GEMINI_MODEL=gemini-3-pro-preview

# Optional local-only testing flag. Leave empty for real Gemini calls.
# KOPIIKI_GEMINI_MOCK=1
